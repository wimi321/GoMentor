{
  "name": "katasensei",
  "version": "0.1.0",
  "description": "Professional KataGo + LLM Go review studio for human learners.",
  "main": "out/main/index.js",
  "type": "module",
  "author": "haoc",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preview": "electron-vite preview",
    "lint": "pnpm typecheck",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "prepare:python": "python3 -m pip install -r scripts/requirements.txt"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "openai": "^6.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "build": {
    "appId": "com.katasensei.desktop",
    "productName": "KataSensei",
    "files": [
      "out/**/*",
      "scripts/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  }
}
